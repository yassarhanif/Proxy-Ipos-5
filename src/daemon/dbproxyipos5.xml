<service>
	<id>dbproxyipos5.exe</id>
	<name>DBProxyIPOS5</name>
	<description>Proxy PostgreSQL read-only API untuk IPOS 5</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>C:\Proxy Ipos 5\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Proxy Ipos 5\src\index.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>DBProxyIPOS5 wrapper</argument>
	<argument>--grow</argument>
	<argument>0.5</argument>
	<argument>--wait</argument>
	<argument>2</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>DESKTOP-6M550IQ</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Proxy Ipos 5</workingdirectory>
</service>